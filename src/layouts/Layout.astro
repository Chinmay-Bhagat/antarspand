---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'The body speaks in waves — Chinmay Bhagat · Biosignal Engineering',
  description = 'Deep dives into BCG signal processing, sleep-stage AI, sensor design, and the engineering behind contactless health monitoring.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Chinmay Bhagat" />
  <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
  <link rel="icon" href="/favicon.png?v=2" type="image/png" sizes="32x32" />
  <link rel="icon" href="/favicon.ico" sizes="any" />

  <!-- OpenGraph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="The body speaks in waves" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,300;1,9..144,400&family=IBM+Plex+Mono:wght@300;400&family=IBM+Plex+Sans:ital,wght@0,300;0,400;1,300&display=swap"
    rel="stylesheet"
  />

  <!-- Canonical URL -->
  <link rel="canonical" href={new URL(Astro.url.pathname, 'https://antarspand.com').href} />

  <!-- JSON-LD: Person + WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://antarspand.com/#chinmay",
        "name": "Chinmay Bhagat",
        "url": "https://antarspand.com",
        "jobTitle": "Senior Data Scientist",
        "worksFor": { "@type": "Organization", "name": "DreamSleep", "url": "https://dreamsleep.co.in" },
        "email": "chinmay@dreamsleep.co.in",
        "sameAs": ["https://www.linkedin.com/in/chinmay-bhagat"],
        "knowsAbout": ["BCG signal processing", "ECG", "HRV", "Sleep staging", "Wearable health tech", "Biosignal engineering"]
      },
      {
        "@type": "WebSite",
        "@id": "https://antarspand.com/#website",
        "url": "https://antarspand.com",
        "name": "The body speaks in waves",
        "description": "Deep dives into BCG signal processing, sleep-stage AI, sensor design, and the engineering behind contactless health monitoring.",
        "author": { "@id": "https://antarspand.com/#chinmay" }
      }
    ]
  })} />

  <!-- Global CSS -->
  <link rel="stylesheet" href="/styles/global.css" />
</head>

<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <div id="cur" aria-hidden="true"></div>

  <header role="banner">
    <a href="/" class="brand" aria-label="AntarSpand — home">
      <span class="brand-name">Antar<em>Spand</em></span>
      <span class="brand-sub" aria-label="HealthTech, Signal Processing, AI/ML">HealthTech · Signal Processing · AI/ML</span>
    </a>
    <nav role="navigation" aria-label="Primary navigation" id="main-nav">
      <a href="/#articles">Articles</a>
      <a href="/about">About</a>
      <a href="/contact" class="nav-connect">Connect →</a>
    </nav>
    <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="main-nav" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </button>
  </header>

  <slot />

  <footer role="contentinfo">
    <p class="foot-brand">Antar<em>Spand</em></p>
    <p class="foot-meta">
      © 2026 Chinmay Bhagat · HealthTech<br />
      <b>BCG</b> · <b>HRV</b> · <b>Sleep Staging</b>
    </p>
  </footer>

  <script>
    'use strict';
    const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ── Mobile Nav Toggle ─────────────────────────── */
    const navToggle = document.getElementById('nav-toggle');
    const mainNav   = document.getElementById('main-nav');
    if (navToggle && mainNav) {
      navToggle.addEventListener('click', () => {
        const open = mainNav.classList.toggle('open');
        navToggle.setAttribute('aria-expanded', String(open));
        const spans = navToggle.querySelectorAll('span');
        spans[0].style.transform = open ? 'rotate(45deg) translate(4px,4px)' : '';
        spans[1].style.opacity   = open ? '0' : '1';
        spans[2].style.transform = open ? 'rotate(-45deg) translate(4px,-4px)' : '';
      });
      mainNav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
        mainNav.classList.remove('open');
        navToggle.setAttribute('aria-expanded', 'false');
      }));
    }

    /* ── Custom Cursor ─────────────────────────────── */
    if (!REDUCED) (function () {
      const cur = document.getElementById('cur');
      if (!cur) return;
      let mx = -300, my = -300, ready = false;
      document.addEventListener('mousemove', e => {
        mx = e.clientX; my = e.clientY;
        if (!ready) {
          ready = true;
          cur.style.display = 'block';
          document.body.style.cursor = 'none';
        }
      }, { passive: true });
      document.addEventListener('mouseleave', () => { cur.style.opacity = '0'; });
      document.addEventListener('mouseenter', () => { cur.style.opacity = '1'; });
      (function loop() {
        cur.style.left = mx + 'px'; cur.style.top = my + 'px';
        requestAnimationFrame(loop);
      })();
      document.querySelectorAll('button, a, .card, .fpill').forEach(el => {
        el.addEventListener('mouseenter', () => { cur.style.width = cur.style.height = '14px'; });
        el.addEventListener('mouseleave', () => { cur.style.width = cur.style.height = '8px'; });
      });
    })();
  </script>
</body>
</html>
